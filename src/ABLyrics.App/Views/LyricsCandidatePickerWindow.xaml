<ui:FluentWindow x:Class="ABLyrics.App.Views.LyricsCandidatePickerWindow"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:views="clr-namespace:ABLyrics.App.Views"
                 xmlns:models="clr-namespace:ABLyrics.App.Models"
                 Title="选择歌词版本"
                 Height="600" Width="900"
                 MinHeight="420" MinWidth="640"
                 WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 顶部：库下拉框 + 当前曲目 -->
        <DockPanel Grid.Row="0" Margin="12,8">
            <TextBlock Text="库:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="LibraryCombo" Width="140" SelectionChanged="OnLibrarySelectionChanged"/>
            <TextBlock x:Name="TrackInfoText" Margin="16,0,0,0" VerticalAlignment="Center" Opacity="0.7"
                       TextTrimming="CharacterEllipsis"/>
        </DockPanel>

        <!-- Row 1: 主体两列 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- 最小 240、最大 480、可用空间不够时收缩；右侧对比区始终拿 '*' -->
                <ColumnDefinition Width="360" MinWidth="240" MaxWidth="480"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：候选列表（点击即勾选/取消，多选用） -->
            <ListBox x:Name="CandidatesList" Grid.Column="0"
                     SelectionMode="Multiple"
                     SelectionChanged="OnCandidateSelectionChanged"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     Margin="8,0,4,8">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#332196F3"/>
                                <Setter Property="BorderBrush" Value="#2196F3"/>
                                <Setter Property="BorderThickness" Value="3,0,0,0"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Background" Value="#11808080"/>
                            </MultiTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="8,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0"
                                     Width="10" Height="10"
                                     Margin="0,0,8,0"
                                     VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#4CAF50"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                <Setter Property="Fill" Value="#F44336"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding DisplayText}" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding DisplayText}"/>
                                <TextBlock Text="{Binding OriginDescription}" Opacity="0.6" FontSize="11"
                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding OriginDescription}"/>
                                <DockPanel>
                                    <TextBlock Text="当前覆盖" Foreground="#FF9800" FontSize="11"
                                               Visibility="{Binding IsOverrideVisibility}"/>
                                    <Button Content="✕" Padding="4,0" Margin="6,0,0,0" FontSize="11"
                                            BorderThickness="0" Background="Transparent"
                                            Foreground="#FF9800"
                                            Visibility="{Binding IsOverrideVisibility}"
                                            ToolTip="清除当前覆盖项"
                                            Click="OnClearOverrideClick"
                                            Tag="{Binding}"
                                            HorizontalAlignment="Left"/>
                                </DockPanel>
                            </StackPanel>
                            <CheckBox Grid.Column="2"
                                      IsChecked="{Binding IsSelected, Mode=OneWay}"
                                      IsHitTestVisible="False"
                                      Focusable="False"
                                      VerticalAlignment="Center"
                                      Margin="4,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 右侧：对比区（1-3 列并排） -->
            <Border Grid.Column="1" Margin="4,0,8,8"
                    BorderBrush="Gray" BorderThickness="1">
                <Grid>
                    <TextBlock x:Name="EmptyCompareText" Text="点击左侧候选以加入对比（最多 3 个）"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Opacity="0.5" FontSize="14"/>
                    <ItemsControl x:Name="CompareColumns" Visibility="Collapsed">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:LyricsCandidate}">
                                <views:CandidateColumnView Loaded="OnCompareColumnLoaded"
                                                           Selected="OnCompareColumnSelected"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>

        <!-- Row 2: 底部：状态文本 + 候选计数 + 按钮 -->
        <DockPanel Grid.Row="2" Margin="12,8">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Opacity="0.7"
                       TextTrimming="CharacterEllipsis"/>
            <TextBlock x:Name="SelectionSummaryText" VerticalAlignment="Center"
                       Margin="12,0,0,0" Opacity="0.7"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button Content="刷新" Padding="12,6" Margin="0,0,8,0" Click="OnRefreshClick"/>
                <Button x:Name="ConfirmButton" Content="应用所选版本" Padding="12,6" Margin="0,0,8,0"
                        IsEnabled="False" Click="OnConfirmClick"
                        ToolTip="在右侧对比区点击列即可高亮选择，再点本按钮应用到主窗口"/>
                <Button Content="关闭" Padding="12,6" Click="OnCloseClick"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</ui:FluentWindow>
