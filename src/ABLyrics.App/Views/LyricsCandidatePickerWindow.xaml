<ui:FluentWindow x:Class="ABLyrics.App.Views.LyricsCandidatePickerWindow"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:views="clr-namespace:ABLyrics.App.Views"
                 Title="选择歌词版本"
                 Height="600" Width="900"
                 WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 顶部：库下拉框 + 当前曲目 -->
        <DockPanel Grid.Row="0" Margin="12,8">
            <TextBlock Text="库:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="LibraryCombo" Width="140" SelectionChanged="OnLibrarySelectionChanged"/>
            <TextBlock x:Name="TrackInfoText" Margin="16,0,0,0" VerticalAlignment="Center" Opacity="0.7"/>
        </DockPanel>

        <!-- Row 1: 主体两列 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：候选列表 -->
            <ListBox x:Name="CandidatesList" Grid.Column="0"
                     SelectionMode="Single"
                     SelectionChanged="OnCandidateSelected"
                     HorizontalContentAlignment="Stretch"
                     Margin="8,0,4,8">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0"
                                     Width="10" Height="10"
                                     Margin="0,0,8,0"
                                     VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#4CAF50"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                <Setter Property="Fill" Value="#F44336"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding DisplayText}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding OriginDescription}" Opacity="0.6" FontSize="11"/>
                                <TextBlock Text="当前覆盖" Foreground="#FF9800" FontSize="11"
                                           Visibility="{Binding IsOverrideVisibility}"/>
                            </StackPanel>
                            <RadioButton Grid.Column="2" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                         VerticalAlignment="Center" GroupName="CandidateGroup"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 右侧：对比区 -->
            <Border Grid.Column="1" Margin="4,0,8,8"
                    BorderBrush="Gray" BorderThickness="1">
                <Grid>
                    <TextBlock x:Name="EmptyCompareText" Text="勾选候选以对比"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Opacity="0.5" FontSize="14"/>
                    <ItemsControl x:Name="CompareColumns" Visibility="Collapsed">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <views:CandidateColumnView/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>

        <!-- Row 2: 底部：状态文本 + 按钮 -->
        <DockPanel Grid.Row="2" Margin="12,8">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Opacity="0.7"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button Content="刷新" Padding="12,6" Margin="0,0,8,0" Click="OnRefreshClick"/>
                <Button x:Name="ConfirmButton" Content="确认" Padding="12,6" Margin="0,0,8,0"
                        IsEnabled="False" Click="OnConfirmClick"/>
                <Button Content="关闭" Padding="12,6" Click="OnCloseClick"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</ui:FluentWindow>