<Window x:Class="ABLyrics.App.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ABLyrics Overlay"
        Width="720"
        Height="120"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        MouseLeftButtonDown="OnDragStart">
    <Border x:Name="ChromeBorder"
            CornerRadius="12"
            BorderBrush="#33FFFFFF"
            BorderThickness="1">
        <StackPanel>
            <StackPanel x:Name="TrackInfoPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <TextBlock x:Name="TrackTitleText"
                           Text="{Binding TrackTitle}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="300" />
                <TextBlock Text=" · "
                           Foreground="#666666" />
                <TextBlock x:Name="ArtistNameText"
                           Text="{Binding ArtistName}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="300" />
                <TextBlock x:Name="RefreshButton"
                           Text=" 🔄"
                           Cursor="Hand"
                           Foreground="#7AD7FF"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           MouseLeftButtonDown="OnRefreshClick" />
                <TextBlock x:Name="SourceTagText"
                           Text="{Binding LyricsSource}"
                           Cursor="Hand"
                           Foreground="#7AD7FF"
                           VerticalAlignment="Center"
                           Margin="6,0,0,0"
                           MouseLeftButtonDown="OnSourceTagClick" />
                <TextBlock Text=" ▼"
                           FontSize="8"
                           Foreground="#666666"
                           Cursor="Hand"
                           VerticalAlignment="Center"
                           MouseLeftButtonDown="OnSourceTagClick" />
            </StackPanel>
            <StackPanel x:Name="LyricsPanel">
                <TextBlock x:Name="SecondaryLineText"
                       Text="{Binding PreviousLine}"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Visibility="Collapsed" />
            <TextBlock x:Name="PrimaryLineText"
                       Text="{Binding CurrentLine}"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap"
                       TextAlignment="Center" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
