<ui:FluentWindow x:Class="ABLyrics.App.Views.StyleSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="样式设置"
        Height="640"
        Width="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:NavigationView x:Name="NavView"
                           Grid.Row="0" Grid.Column="0"
                           Width="220"
                           IsBackButtonVisible="Collapsed"
                           PaneDisplayMode="Left"
                           OpenPaneLength="220">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="外观" TargetPageTag="appearance" Click="OnMenuItemClick" />
                <ui:NavigationViewItem Content="同步" TargetPageTag="sync" Click="OnMenuItemClick" />
                <ui:NavigationViewItem Content="关于" TargetPageTag="about" Click="OnMenuItemClick" />
                <ui:NavigationViewItem Content="播放来源" TargetPageTag="playback-source" Click="OnMenuItemClick" />
                <ui:NavigationViewItem Content="歌词" TargetPageTag="lyrics" Click="OnMenuItemClick" />
            </ui:NavigationView.MenuItems>
        </ui:NavigationView>

        <Grid Grid.Row="0" Grid.Column="1">

            <ScrollViewer x:Name="AppearancePage" Visibility="Visible"
                          VerticalScrollBarVisibility="Auto" Padding="24">
                <StackPanel>
                    <!-- 外观分块 -->
                    <ui:Card Padding="20" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="字体" Margin="0,0,0,8" />
                            <ComboBox x:Name="FontFamilyCombo"
                                      Height="32"
                                      Margin="0,0,0,16"
                                      MaxDropDownHeight="280"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      VirtualizingStackPanel.IsVirtualizing="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                                      PreviewMouseLeftButtonDown="OnFontComboPreviewMouseLeftButtonDown"
                                      PreviewKeyDown="OnFontComboPreviewKeyDown" />

                            <TextBlock Text="歌词字号" Margin="0,0,0,8" />
                            <DockPanel Margin="0,0,0,16">
                                <TextBlock x:Name="FontSizeLabel"
                                           DockPanel.Dock="Right"
                                           Width="40"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right" />
                                <Slider x:Name="FontSizeSlider"
                                        Minimum="12"
                                        Maximum="36"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True" />
                            </DockPanel>

                            <TextBlock Text="歌曲信息字号" Margin="0,0,0,8" />
                            <DockPanel Margin="0,0,0,16">
                                <TextBlock x:Name="SongInfoFontSizeLabel"
                                           DockPanel.Dock="Right"
                                           Width="40"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right" />
                                <Slider x:Name="SongInfoFontSizeSlider"
                                        Minimum="8"
                                        Maximum="24"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True" />
                            </DockPanel>

                            <TextBlock Text="字距 (px)" Margin="0,0,0,8" />
                            <DockPanel>
                                <TextBlock x:Name="LetterSpacingLabel"
                                           DockPanel.Dock="Right"
                                           Width="40"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right" />
                                <Slider x:Name="LetterSpacingSlider"
                                        Minimum="-2"
                                        Maximum="20"
                                        TickFrequency="0.5"
                                        IsSnapToTickEnabled="True" />
                            </DockPanel>
                        </StackPanel>
                    </ui:Card>

                    <!-- 布局分块 -->
                    <ui:Card Padding="20" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="框高度 (px)" Margin="0,0,0,8" />
                            <DockPanel Margin="0,0,0,16">
                                <TextBlock x:Name="BarHeightLabel"
                                           DockPanel.Dock="Right"
                                           Width="40"
                                           VerticalAlignment="Center" />
                                <Slider x:Name="BarHeightSlider"
                                        Minimum="28"
                                        Maximum="120"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True" />
                            </DockPanel>

                            <TextBlock Text="四周边距 (px)" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                                    <TextBlock Text="左" FontSize="11" Opacity="0.7" Margin="0,0,0,4" />
                                    <ui:TextBox x:Name="PaddingLeftBox" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,12">
                                    <TextBlock Text="上" FontSize="11" Opacity="0.7" Margin="0,0,0,4" />
                                    <ui:TextBox x:Name="PaddingTopBox" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="右" FontSize="11" Opacity="0.7" Margin="0,0,0,4" />
                                    <ui:TextBox x:Name="PaddingRightBox" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="下" FontSize="11" Opacity="0.7" Margin="0,0,0,4" />
                                    <ui:TextBox x:Name="PaddingBottomBox" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="显示行数" Margin="0,0,0,12" />
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="OneLineRadio"
                                             Content="1 行"
                                             Margin="0,0,24,0"
                                             GroupName="LineCount" />
                                <RadioButton x:Name="TwoLineRadio"
                                             Content="2 行"
                                             GroupName="LineCount" />
                            </StackPanel>
                        </StackPanel>
                    </ui:Card>

                    <!-- 颜色分块 -->
                    <ui:Card Padding="20" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="背景" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBlock Text="底色 (RGB Hex)" Margin="0,0,0,8" />
                            <ui:TextBox x:Name="BackgroundColorBox" Margin="0,0,0,4" />
                            <TextBlock Text="例如 #101010" FontSize="11" Opacity="0.6" Margin="0,0,0,12" />

                            <TextBlock Text="背景透明度" Margin="0,0,0,8" />
                            <DockPanel Margin="0,0,0,12">
                                <TextBlock x:Name="OpacityLabel"
                                           DockPanel.Dock="Right"
                                           Width="48"
                                           VerticalAlignment="Center" />
                                <Slider x:Name="OpacitySlider"
                                        Minimum="0"
                                        Maximum="1"
                                        TickFrequency="0.05" />
                            </DockPanel>

                            <TextBlock Text="叠加基准色（透明时显示此色）" FontSize="11" Opacity="0.7" Margin="0,0,0,4" />
                            <ui:TextBox x:Name="OverlayBaseColorBox" />
                        </StackPanel>
                    </ui:Card>

                    <!-- 颜色分块：单一前景色 + 推荐 swatch -->
                    <ui:Card Padding="20" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="前景色" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBlock Text="所有前景元素使用此色，副级元素（歌手/副歌词/曲名）按下方透明度自动变暗。点击右侧方块可直接填入 WCAG AA 推荐值。" TextWrapping="Wrap" Opacity="0.6" FontSize="11" Margin="0,0,0,12" />

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="40" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBox x:Name="ForegroundColorBox" Grid.Column="0" />
                                <ui:Button x:Name="RecommendForegroundWhiteButton" Grid.Column="1"
                                           Margin="4,0,0,0" Height="32" Padding="0"
                                           Tag="white" Click="OnRecommendSwatchClick"
                                           ToolTip="填入白色（WCAG AA 推荐）">
                                    <Border Width="20" Height="20" Background="White" BorderBrush="#888" BorderThickness="1" />
                                </ui:Button>
                                <ui:Button x:Name="RecommendForegroundBlackButton" Grid.Column="2"
                                           Margin="4,0,0,0" Height="32" Padding="0"
                                           Tag="black" Click="OnRecommendSwatchClick"
                                           ToolTip="填入黑色（WCAG AA 推荐）">
                                    <Border Width="20" Height="20" Background="Black" BorderBrush="#888" BorderThickness="1" />
                                </ui:Button>
                            </Grid>

                            <TextBlock Text="副级元素透明度" Margin="0,0,0,8" />
                            <DockPanel>
                                <TextBlock x:Name="ForegroundOpacityLabel"
                                           DockPanel.Dock="Right"
                                           Width="48"
                                           VerticalAlignment="Center" />
                                <Slider x:Name="ForegroundOpacitySlider"
                                        Minimum="0.3"
                                        Maximum="1.0"
                                        TickFrequency="0.05"
                                        IsSnapToTickEnabled="True" />
                            </DockPanel>
                        </StackPanel>
                    </ui:Card>

                    <!-- 预览 -->
                    <ui:Card Padding="20">
                        <StackPanel>
                            <TextBlock Text="预览" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <Border x:Name="PreviewBorder"
                                    CornerRadius="6"
                                    Padding="12,6">
                                <StackPanel>
                                    <TextBlock x:Name="PreviewSecondary"
                                               Text="上一行歌词预览"
                                               TextAlignment="Center"
                                               Margin="0,0,0,2" />
                                    <TextBlock x:Name="PreviewPrimary"
                                               Text="当前行歌词预览"
                                               TextAlignment="Center" />
                                    <TextBlock x:Name="PreviewEnglish"
                                               Text="And the preview line in English"
                                               TextAlignment="Center"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ui:Card>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="SyncPage" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto" Padding="24">
                <StackPanel>
                    <TextBlock Text="歌词同步" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
                    <ui:Card Padding="20">
                        <StackPanel>
                            <TextBlock Text="同步偏移 (ms)" Margin="0,0,0,8" />
                            <DockPanel Margin="0,0,0,12">
                                <TextBlock x:Name="SyncOffsetLabel"
                                           DockPanel.Dock="Right"
                                           Width="40"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right" />
                                <Slider x:Name="SyncOffsetSlider"
                                        Minimum="0"
                                        Maximum="500"
                                        TickFrequency="10"
                                        IsSnapToTickEnabled="True" />
                            </DockPanel>
                            <TextBlock TextWrapping="Wrap" Opacity="0.7" FontSize="12"
                                       Text="正值让歌词延后显示，负值让歌词提前显示。如果歌词总是慢/快半拍，可以微调此值。" />
                        </StackPanel>
                    </ui:Card>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="PlaybackSourcePage" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto" Padding="24">
                <StackPanel>
                    <TextBlock Text="播放进度来源" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
                    <ui:Card Padding="20" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="活动来源" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock x:Name="ActiveSourceNameText" Text="(未选择)" Margin="0,0,0,4" />
                            <TextBlock x:Name="ActiveSourceStatusText" Opacity="0.7" Margin="0,0,0,12" />
                            <StackPanel Orientation="Horizontal">
                                <ui:Button x:Name="ConnectSourceButton" Content="连接"
                                           Width="84" Margin="0,0,8,0" Click="OnConnectSourceClick" />
                                <ui:Button x:Name="DisconnectSourceButton" Content="断开"
                                           Width="84" Click="OnDisconnectSourceClick" />
                            </StackPanel>
                        </StackPanel>
                    </ui:Card>

                    <ui:Card x:Name="SpotifyDetailCard" Padding="20" Margin="0,0,0,16" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Spotify" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock x:Name="SpotifyStatusDetailText" Opacity="0.7" Margin="0,0,0,12" />
                            <TextBlock x:Name="SpotifyUnavailableHint"
                                       TextWrapping="Wrap" FontSize="12" Opacity="0.7"
                                       Visibility="Collapsed"
                                       Text="请在 appsettings.json 中配置 Spotify.ClientId，然后重启应用。" />
                        </StackPanel>
                    </ui:Card>

                    <ui:Card Padding="20">
                        <StackPanel>
                            <TextBlock Text="可用来源" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <ItemsControl x:Name="AvailableSourcesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8" Margin="0,0,0,8" CornerRadius="4"
                                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding StatusText}" Opacity="0.7" FontSize="12" />
                                                </StackPanel>
                                                <ui:Button Grid.Column="1" Content="使用此来源"
                                                           Click="OnUseSourceClick"
                                                           Tag="{Binding Id}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ui:Card>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="LyricsPage" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto" Padding="24">
                <StackPanel>
                    <TextBlock Text="歌词" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
                    <ui:Card Padding="20" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="本地歌词" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <DockPanel>
                                <ui:ToggleSwitch x:Name="PromptLocalMissingSwitch"
                                                 DockPanel.Dock="Right"
                                                 Content="缺失时弹出选择对话框"
                                                 Click="OnPromptLocalMissingToggled" />
                            </DockPanel>
                            <TextBlock TextWrapping="Wrap" Opacity="0.7" FontSize="12" Margin="0,8,0,0"
                                       Text="切换到本地歌词源时，若在歌词库找不到当前曲目，会弹出文件选择框。关闭后不再提示，需要时可使用顶部 AppBar 菜单「Local ▸ 导入歌词文件…」。" />
                        </StackPanel>
                    </ui:Card>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="AboutPage" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto" Padding="24">
                <StackPanel>
                    <TextBlock Text="关于" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
                    <ui:Card Padding="20">
                        <StackPanel>
                            <TextBlock Text="ABLyrics" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock Text="Windows 桌面歌词小组件" Opacity="0.7" Margin="0,4,0,16" />
                            <TextBlock Text="技术栈" Opacity="0.6" FontSize="12" Margin="0,0,0,4" />
                            <TextBlock Text=".NET 8 + WPF + WPF-UI (lepoco)" Margin="0,0,0,12" />
                            <TextBlock Text="歌词源" Opacity="0.6" FontSize="12" Margin="0,0,0,4" />
                            <TextBlock Text="LRCLIB · Netease · 本地 .lrc" Margin="0,0,0,12" />
                            <TextBlock Text="许可" Opacity="0.6" FontSize="12" Margin="0,0,0,4" />
                            <TextBlock Text="MIT" />
                        </StackPanel>
                    </ui:Card>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="1" Grid.ColumnSpan="2" Padding="20,12"
                Background="{DynamicResource ControlFillColorDefaultBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="取消"
                           Width="84"
                           Margin="0,0,8,0"
                           Click="OnCancelClick" />
                <ui:Button Content="应用"
                           Width="84"
                           Margin="0,0,8,0"
                           Click="OnApplyClick" />
                <ui:Button Content="确定"
                           Width="84"
                           Appearance="Primary"
                           Click="OnConfirmClick" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>