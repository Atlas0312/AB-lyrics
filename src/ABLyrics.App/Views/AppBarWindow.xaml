<Window x:Class="ABLyrics.App.Views.AppBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ABLyrics AppBar"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        AllowsTransparency="True"
        Height="56">
    <Border x:Name="ChromeBorder">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MaxWidth="300" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 左侧：曲名 · 歌手（横向） -->
            <StackPanel x:Name="TrackInfoPanel"
                        Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="8,0">
                <TextBlock x:Name="TrackTitleText"
                           Text="{Binding TrackTitle}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="140" />
                <TextBlock Text=" · "
                           Foreground="#666666"
                           Margin="2,0" />
                <TextBlock x:Name="ArtistNameText"
                           Text="{Binding ArtistName}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="140" />
            </StackPanel>

            <!-- 中间：歌词 -->
            <StackPanel x:Name="LyricsPanel"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock x:Name="SecondaryLineText"
                           Text="{Binding PreviousLine}"
                           TextTrimming="CharacterEllipsis"
                           TextAlignment="Center"
                           Visibility="Collapsed" />
                <TextBlock x:Name="PrimaryLineText"
                           Text="{Binding CurrentLine}"
                           TextTrimming="CharacterEllipsis"
                           TextAlignment="Center" />
            </StackPanel>

            <!-- 右侧：刷新按钮 + 源标签 -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0">
                <TextBlock x:Name="RefreshButton"
                           Text="🔄"
                           Cursor="Hand"
                           Foreground="#7AD7FF"
                           Margin="0,0,6,0"
                           MouseLeftButtonDown="OnRefreshClick" />
                <TextBlock x:Name="SourceTagText"
                           Text="{Binding LyricsSource}"
                           Cursor="Hand"
                           MouseLeftButtonDown="OnSourceTagClick" />
                <TextBlock Text=" ▼"
                           FontSize="8"
                           Foreground="#666666"
                           Cursor="Hand"
                           VerticalAlignment="Center"
                           MouseLeftButtonDown="OnSourceTagClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
